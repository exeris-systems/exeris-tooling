{
  "name": "@exeris/codegen-ts",
  "version": "0.2.0",
  "description": "Exeris Frontend Generator (Angular 21+)",
  "type": "module",
  "bin": {
    "exeris-gen": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "node scripts/coverage-gate.mjs",
    "verify:generated": "npm run build && node scripts/verify-generated-frontend.mjs",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "keywords": [
    "exeris",
    "codegen",
    "angular",
    "typescript",
    "generator"
  ],
  "author": "Exeris Team",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.9",
    "@vitest/coverage-v8": "^4.1.6",
    "rimraf": "^6.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "handlebars": "^4.7.8",
    "picocolors": "^1.1.0",
    "zod": "^3.24.0"
  }
}
